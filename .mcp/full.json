{
  "mcpServers": {
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp"
    },
    "anki": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "--directory",
        "${HOME}/.mcp/anki-mcp",
        "run",
        "server.py"
      ],
      "env": {}
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--browser=chrome",
        "--headless",
        "--isolated",
        "--viewport-size=1920,1080",
        "--storage-state=${HOME}/.playwright-profiles/storage-state.json"
      ],
      "env": {}
    }
  }
}
