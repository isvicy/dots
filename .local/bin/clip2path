#!/usr/bin/env bash
set -e

if [ -n "$WAYLAND_DISPLAY" ]; then
    types=$(wl-paste --list-types 2>/dev/null || true)

    if grep -q '^image/' <<<"$types"; then
        ext=$(grep -m1 '^image/' <<<"$types" | cut -d/ -f2 | cut -d';' -f1)
        file="/tmp/clip_$(date +%s).${ext}"
        wl-paste --type "image/${ext}" > "$file"
        printf '%q' "$file" | kitty @ send-text --stdin
    else
        wl-paste --no-newline 2>/dev/null | kitty @ send-text --stdin
    fi
else
    if xclip -selection clipboard -t TARGETS -o 2>/dev/null | grep -q '^image/'; then
        ext=$(xclip -selection clipboard -t TARGETS -o | grep -m1 '^image/' | cut -d/ -f2)
        file="/tmp/clip_$(date +%s).${ext}"
        xclip -selection clipboard -t "image/${ext}" -o > "$file"
        printf '%q' "$file" | kitty @ send-text --stdin
    else
        xclip -selection clipboard -o 2>/dev/null | kitty @ send-text --stdin
    fi
fi
